# ─── База данных (PostgreSQL) ──────────────────────────────
# Локально: postgresql://postgres:postgres@localhost:5432/dryleaf
# Supabase/Neon: возьми строку подключения из дашборда
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dryleaf?schema=public"

# ─── Auth.js (NextAuth) ────────────────────────────────────
# Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-please"
NEXTAUTH_URL="http://localhost:3000"

# ─── Stripe ────────────────────────────────────────────────
# Тестовые ключи: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Секрет вебхука: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Realtime (Supabase) — опционально ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ─── Базовый URL для генерации QR столиков ─────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Сид первого админа ────────────────────────────────────
SEED_ADMIN_EMAIL="admin@dryleaf.local"
SEED_ADMIN_PASSWORD="dryleaf123"
